import { Palette } from "palette.slint";
import { ActionBtn } from "components.slint";

export struct MealSlot {
    time: string,
    label: string,
    accent: color,
    content: string,
    index: int,
}

export component MenuView inherits Rectangle {
    background: Palette.bg;

    in property <[MealSlot]> meals;
    in property <bool> lang-en;
    callback meal-add;
    callback meal-edit-open(int);

    VerticalLayout {
        padding: 20px; spacing: 0px;

        // Header
        HorizontalLayout {
            alignment: stretch; spacing: 8px;
            VerticalLayout {
                spacing: 2px; horizontal-stretch: 1;
                Text { text: lang-en ? "Today's Meals" : "Repas du Jour"; font-size: Palette.fs-title; font-weight: 700; color: Palette.text; }
                Text { text: lang-en ? "Reference nutrition plan" : "Plan nutritionnel de référence"; font-size: Palette.fs-md - 0.5px; color: Palette.text2; }
            }
            // Add meal button
            ActionBtn {
                label: "+"; primary: true; small: true;
                width: 36px;
                clicked => { root.meal-add(); }
            }
        }

        Rectangle { height: 16px; }

        Flickable {
            vertical-stretch: 1;
            viewport-height: meals-col.preferred-height;

            meals-col := VerticalLayout {
                spacing: 10px;

                for meal in root.meals : Rectangle {
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: Palette.card-border;
                    background: Palette.card;

                    // Long-press → edit
                    lp-timer := Timer {
                        interval: 500ms; running: false;
                        triggered => { self.running = false; root.meal-edit-open(meal.index); }
                    }
                    TouchArea {
                        pointer-event(pe) => {
                            if pe.kind == PointerEventKind.down { lp-timer.running = true; }
                            if pe.kind == PointerEventKind.up || pe.kind == PointerEventKind.cancel { lp-timer.running = false; }
                        }
                    }

                    // Left accent bar
                    Rectangle {
                        x: 0px; y: 0px;
                        width: 3px; height: parent.height;
                        border-radius: 2px;
                        background: meal.accent;
                    }

                    VerticalLayout {
                        padding-left: 14px; padding-right: 14px;
                        padding-top: 12px; padding-bottom: 12px;
                        spacing: 6px;

                        HorizontalLayout {
                            spacing: 8px; alignment: start;
                            Text {
                                text: meal.time;
                                font-size: Palette.fs-md - 0.5px; font-weight: 600;
                                color: meal.accent;
                                letter-spacing: 1px;
                            }
                            Text {
                                text: meal.label;
                                font-size: Palette.fs-lg; font-weight: 700;
                                color: Palette.text;
                                horizontal-stretch: 1;
                            }
                            // edit hint
                            Text {
                                text: "✎";
                                font-size: Palette.fs-xs;
                                color: Palette.text3;
                                vertical-alignment: center;
                            }
                        }

                        Text {
                            text: meal.content;
                            font-size: Palette.fs - 0.5px; color: Palette.text2;
                            wrap: word-wrap;
                        }
                    }
                }
            }
        }
    }
}
