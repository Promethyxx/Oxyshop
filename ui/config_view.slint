import { Palette } from "palette.slint";
import { ActionBtn, IconBtn } from "components.slint";

export component ConfigView inherits Rectangle {
    background: Palette.bg;

    in-out property <string> dav-url;
    in-out property <string> dav-user;
    in-out property <string> dav-pass;
    in property <bool> lang-en;

    callback save-config;
    callback test-dav;
    callback clear-config;
    callback export-data;
    callback import-data;
    callback theme-toggle;
    callback font-smaller;
    callback font-larger;

    VerticalLayout {
        padding: 20px; spacing: 0px;

        // Header
        HorizontalLayout {
            alignment: stretch; spacing: 8px;
            VerticalLayout {
                spacing: 2px; horizontal-stretch: 1;
                Text { text: "Configuration"; font-size: Palette.fs-title; font-weight: 700; color: Palette.text; }
                Text { text: lang-en ? "WebDAV connection for sync" : "Connexion WebDAV pour la synchronisation"; font-size: Palette.fs-md - 0.5px; color: Palette.text2; }
            }
            HorizontalLayout {
                spacing: 6px; alignment: end;
                IconBtn { label: Palette.dark ? "🌙" : "☀️"; clicked => { root.theme-toggle(); } }
                IconBtn { label: "A−"; clicked => { root.font-smaller(); } }
                IconBtn { label: "A+"; clicked => { root.font-larger(); } }
            }
        }

        Rectangle { height: 16px; }

        Flickable {
            vertical-stretch: 1;
            viewport-height: cfg-col.preferred-height;

            cfg-col := VerticalLayout {
                spacing: 10px;

                // WebDAV section
                Rectangle {
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: Palette.card-border;
                    background: Palette.card;

                    VerticalLayout {
                        padding: 14px; spacing: 8px;

                        Text {
                            text: "☁️  WEBDAV (NEXTCLOUD, KDRIVE, ETC.)";
                            font-size: Palette.fs-xs + 0.5px; font-weight: 600;
                            color: Palette.text3; letter-spacing: 1px;
                        }

                        // URL
                        VerticalLayout {
                            spacing: 3px;
                            Text { text: lang-en ? "WebDAV folder URL" : "URL du dossier WebDAV"; font-size: Palette.fs-md - 0.5px; color: Palette.text2; }
                            Rectangle {
                                height: 36px; border-radius: 8px;
                                border-width: 1px;
                                border-color: url-ti.has-focus ? rgba(232,168,124,0.3) : Palette.card-border;
                                background: Palette.card; clip: true;
                                url-ti := TextInput {
                                    x: 8px; y: 0px;
                                    width: parent.width - 16px;
                                    height: parent.height;
                                    text <=> root.dav-url;
                                    font-size: Palette.fs - 0.5px; color: Palette.text;
                                    horizontal-alignment: left; vertical-alignment: center;
                                }
                                if url-ti.text == "" && !url-ti.has-focus : Text {
                                    x: 8px; y: (parent.height - self.preferred-height) / 2;
                                    text: "https://cloud.example.com/remote.php/dav/files/user/Oxy/";
                                    font-size: Palette.fs - 0.5px; color: Palette.text3;
                                }
                            }
                        }

                        // User
                        VerticalLayout {
                            spacing: 3px;
                            Text { text: lang-en ? "Username" : "Nom d'utilisateur"; font-size: Palette.fs-md - 0.5px; color: Palette.text2; }
                            Rectangle {
                                height: 36px; border-radius: 8px;
                                border-width: 1px;
                                border-color: user-ti.has-focus ? rgba(232,168,124,0.3) : Palette.card-border;
                                background: Palette.card; clip: true;
                                user-ti := TextInput {
                                    x: 8px; y: 0px;
                                    width: parent.width - 16px;
                                    height: parent.height;
                                    text <=> root.dav-user;
                                    font-size: Palette.fs - 0.5px; color: Palette.text;
                                    horizontal-alignment: left; vertical-alignment: center;
                                }
                                if user-ti.text == "" && !user-ti.has-focus : Text {
                                    x: 8px; y: (parent.height - self.preferred-height) / 2;
                                    text: "ton@email.com";
                                    font-size: Palette.fs - 0.5px; color: Palette.text3;
                                }
                            }
                        }

                        // Password
                        VerticalLayout {
                            spacing: 3px;
                            Text { text: lang-en ? "Password (or app password)" : "Mot de passe (ou app password)"; font-size: Palette.fs-md - 0.5px; color: Palette.text2; }
                            Rectangle {
                                height: 36px; border-radius: 8px;
                                border-width: 1px;
                                border-color: pass-ti.has-focus ? rgba(232,168,124,0.3) : Palette.card-border;
                                background: Palette.card; clip: true;
                                pass-ti := TextInput {
                                    x: 8px; y: 0px;
                                    width: parent.width - 16px;
                                    height: parent.height;
                                    text <=> root.dav-pass;
                                    input-type: password;
                                    font-size: Palette.fs - 0.5px; color: Palette.text;
                                    horizontal-alignment: left; vertical-alignment: center;
                                }
                                if pass-ti.text == "" && !pass-ti.has-focus : Text {
                                    x: 8px; y: (parent.height - self.preferred-height) / 2;
                                    text: "••••••••";
                                    font-size: Palette.fs - 0.5px; color: Palette.text3;
                                }
                            }
                        }

                        // Buttons
                        HorizontalLayout {
                            spacing: 8px;
                            ActionBtn { label: lang-en ? "Save" : "Sauver";   primary: true;  small: true; width: 80px;  clicked => { root.save-config(); } }
                            ActionBtn { label: lang-en ? "Test" : "Tester";   primary: false; small: true; width: 80px;  clicked => { root.test-dav(); } }
                            ActionBtn { label: lang-en ? "Clear" : "Effacer"; primary: false; small: true; width: 80px;  clicked => { root.clear-config(); } }
                        }
                    }
                }

                // Import / Export section
                Rectangle {
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: Palette.card-border;
                    background: Palette.card;

                    VerticalLayout {
                        padding: 14px; spacing: 10px;

                        Text {
                            text: lang-en ? "💾  MANUAL IMPORT / EXPORT" : "💾  IMPORT / EXPORT MANUEL";
                            font-size: Palette.fs-xs + 0.5px; font-weight: 600;
                            color: Palette.text3; letter-spacing: 1px;
                        }

                        HorizontalLayout {
                            spacing: 8px;
                            ActionBtn { label: lang-en ? "📤 Export" : "📤 Exporter";     primary: false; small: true; width: 120px; clicked => { root.export-data(); } }
                            ActionBtn { label: lang-en ? "📂 Browse..." : "📂 Parcourir..."; primary: true; small: true; width: 140px; clicked => { root.import-data(); } }
                        }
                    }
                }
            }
        }
    }
}
